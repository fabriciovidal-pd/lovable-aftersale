# =====================================================================
# .env.example — Variáveis de ambiente da aplicação
# Copie este arquivo para `.env` (desenvolvimento) e preencha os valores.
# Em produção (Kubernetes/OKE), use ConfigMap (NODE_ENV, PORT, VITE_*)
# e Secret (qualquer chave/credencial).
# =====================================================================

# Ambiente de execução do Node (development | production)
NODE_ENV=production

# Porta HTTP exposta pelo container (Nginx escuta nessa porta)
PORT=8080

# (Opcional) URL pública do site — usada para metadata/SEO se aplicável
PUBLIC_SITE_URL=https://exemplo.com.br

# ---------------------------------------------------------------------
# Variáveis VITE_* são embutidas no bundle em BUILD TIME.
# Defina-as no momento do `bun run build` (ConfigMap + build args).
# NUNCA coloque segredos reais em variáveis VITE_*: elas são públicas.
# ---------------------------------------------------------------------

# (Exemplo / opcional) Endpoint público da API consumida pelo front
VITE_API_BASE_URL=https://api.exemplo.com.br

# (Exemplo / opcional) ID público de analytics
VITE_ANALYTICS_ID=GA-XXXXXXXXX
